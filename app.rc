#include <windows.h>

// Manifest enables Common Controls v6 (modern Visual Styles) and DPI awareness.
// Resource ID 1 + type RT_MANIFEST (24) is the standard application manifest.
1 24 "app.manifest"

1 ICON "app.ico"

1 VERSIONINFO
FILEVERSION    2,5,2,0
PRODUCTVERSION 2,5,2,0
FILEFLAGSMASK  0x3fL
FILEFLAGS      0x0L
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Invisible AI Overlay Project"
            VALUE "FileDescription",  "Invisible AI Overlay - Live Interview & Study Copilot"
            VALUE "FileVersion",      "2.5.2.0"
            VALUE "InternalName",     "overlay"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "overlay.exe"
            VALUE "ProductName",      "Invisible AI Overlay"
            VALUE "ProductVersion",   "2.5.2.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
